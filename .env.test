# .env.test
# Environment variables for testing

# Database connection (could be a test database)
DATABASE_URL=postgres://user:password@hostname:5432/server-list-test

# Auth settings
AUTH_SECRET=test-secret-do-not-use-in-production
OIDC_ISSUER_URL=http://localhost:5556/dex
AUTH_CLIENT_ID=FoundInTheDexConfig
AUTH_CLIENT_SECRET=FoundInTheDexConfig

# Test user credentials for LDAP login
TEST_USERNAME=test-user
TEST_PASSWORD=test-password

# Other settings
REDIS_URL=redis://localhost:6379
API_URL=http://localhost:3000
SCAN_TOKEN=test-scan-token